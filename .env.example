# Ollama / Local LLM
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=qwen3:4b

# Input / Output files
NEWS_INPUT_PATH=data/news.jsonl
NEWS_ANALYZED_OUTPUT_PATH=data/analyzed_news.jsonl

# Analysis settings
MIN_TEXT_LENGTH=200
LLM_TIMEOUT_SECONDS=300
LLM_TEMPERATURE=0.2
LLM_NUM_PREDICT=1200

# Streamlit dashboard
DASHBOARD_DATA_PATH=data/analyzed_news.jsonl